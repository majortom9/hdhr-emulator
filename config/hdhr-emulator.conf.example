# hdhr-emulator config — key=value, '#' comments, missing file = all defaults.

# 32-bit device ID advertised in discovery/HTTP. Leave unset to get a
# random-but-checksum-valid one generated at each startup (fine, but
# means Plex/Emby will see a "new" device every restart — set this to a
# fixed value once you're happy with the setup so DVR pairing sticks).
# Must satisfy the real HDHomeRun checksum to be accepted by official
# SiliconDust apps; run `./hdhr-emulator --gen-device-id` to print a fresh
# valid one, then paste it here.
#device_id=0x1042304F

friendly_name=HDHomeRun Connect
model=HDHR4-2US
firmware_name=hdhomerun4_atsc
firmware_version=20260313

# Number of tuners to advertise — each slot maps 1:1 to one physical USB
# ATSC tuner (a real DVB frontend can only be locked to one RF frequency
# at a time, so N tuner slots really does mean N independent physical
# devices, same as genuine HDHomeRun hardware).
tuner_count=2

# IP to advertise in discovery replies/BaseURL. Leave as 0.0.0.0 to
# auto-detect per-request (correct if the Pi has one LAN interface, which
# is the common case); set explicitly if you have multiple interfaces and
# want a specific one advertised.
bind_ip=0.0.0.0

# --- DVB backend ---
# By default tuner0 -> /dev/dvb/adapter0, tuner1 -> /dev/dvb/adapter1,
# etc. (identity mapping). Override individual slots if your tuners
# don't enumerate in that order, e.g. if adapter0 is some other DVB
# device on the system and your ATSC USB tuner shows up as adapter1:
tuner0_adapter=1
tuner1_adapter=2

# Frontend/demux number *within* each adapter — virtually all consumer
# USB ATSC dongles only expose frontend0/demux0/dvr0, so these almost
# never need changing.
dvb_frontend=0
dvb_demux=0

# Runs a full ATSC channel scan (US RF channels 2-36 — the post-repack
# usable range; see atsc_freq.h — ~1 minute) on tuner0's adapter at startup, populating the channel database every
# other tuner slot shares. Discovery/control/HTTP come up immediately
# regardless — the scan runs in the background, so clients that poll
# lineup.json right after startup will just see an empty (or partial)
# lineup until it finishes (unless channel_cache_file below is set, in
# which case the last-saved lineup loads immediately instead). To
# rescan at runtime without restarting, just walk the channel map from
# a client, e.g. `hdhomerun_config <deviceid> scan <tuner> <output>` —
# the daemon updates the live channel database (and lineup.json) as
# each frequency locks, without needing a dedicated "rescan" verb.
scan_on_startup=1

# Optional path to a cache file the daemon saves its channel list to
# after every scan (startup or a manual one triggered as described
# above), and reloads from at the next startup — so lineup.json/
# streaming work immediately from the last-known lineup instead of
# sitting empty until scan_on_startup's background scan finishes.
# Leave unset to disable caching entirely.
#channel_cache_file=/var/lib/hdhr-emulator/channels.cache

# When trying to calibrate signal_strength_pct ("ss=") against a real
# HDHomeRun's readings, set this to 1 and watch stderr — logs the raw
# scale type and value your DVB driver actually reports for
# DTV_STAT_SIGNAL_STRENGTH/CNR on every /tunerN/status read. Needed
# because the DVB API doesn't standardize what physical unit a driver's
# decibel-scale signal strength is in (dBmV, dBm, etc vary by driver) —
# see dvb_frontend.c for the full explanation.
#debug_signal_stats=1

# Off by default: whether a network client can make this daemon exit
# via /sys/restart (real HDHomeRun protocol leaf; see get help). The
# wire protocol has no real authentication (lockkey is an advisory
# courtesy value, not a security boundary), so any client on the LAN
# could otherwise stop the daemon. There's no in-place restart — the
# process just exits, and needs a supervisor (systemd's Restart=always;
# see systemd/hdhr-emulator.service) to bring it back. Only turn this on
# if you're actually running under one and want that recovery path.
#allow_remote_restart=1
